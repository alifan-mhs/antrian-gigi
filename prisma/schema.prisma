generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Operator {
  id                String             @id @default(uuid())
  name              String
  email             String             @unique
  passwordHash      String
  createdAt         DateTime           @default(now())
  sessions          DailySession[]
  confirmedPatients ConfirmedPatient[]
}

model DailySession {
  id            String         @id @default(uuid())
  operator      Operator       @relation(fields: [operatorId], references: [id])
  operatorId    String
  date          DateTime       @db.Date
  quota         Int
  startTime     String         @default("08:00")
  endTime       String         @default("17:00")
  promoText     String?
  isOpen        Boolean        @default(true)
  createdAt     DateTime       @default(now())
  registrations Registration[]

  @@unique([operatorId, date])
}

model Registration {
  id               String             @id @default(uuid())
  session          DailySession       @relation(fields: [sessionId], references: [id])
  sessionId        String
  queueNumber      Int
  name             String
  phone            String
  complaint        String?
  status           RegistrationStatus @default(MENUNGGU)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  confirmedPatient ConfirmedPatient?

  @@unique([sessionId, phone])
  @@index([sessionId, status])
}

enum RegistrationStatus {
  MENUNGGU
  DIHUBUNGI
  DIKONFIRMASI
  SELESAI
  BATAL
  TIDAK_DATANG
}

// Patients scheduled into a fixed afternoon/evening slot instead of the daily
// walk-in quota — usually an existing walk-in Registration the nurse has
// already marked DIKONFIRMASI after a phone/WA follow-up (sourceRegistration
// links back to it so its name/phone/complaint don't need retyping), but
// manual entry (sourceRegistration left null) covers a lead with no walk-in
// registration at all. promoLabel ("Pasien Promo N") auto-increments per
// operator per day.
model ConfirmedPatient {
  id                   String                 @id @default(uuid())
  operator             Operator               @relation(fields: [operatorId], references: [id])
  operatorId           String
  date                 DateTime               @db.Date
  promoLabel           String
  timeSlot             ConfirmedTimeSlot
  name                 String
  phone                String
  complaint            String?
  status               ConfirmedPatientStatus @default(TERKONFIRMASI)
  sourceRegistration   Registration?          @relation(fields: [sourceRegistrationId], references: [id])
  sourceRegistrationId String?                @unique
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt

  @@index([operatorId, date])
  @@index([date, timeSlot])
}

enum ConfirmedTimeSlot {
  SIANG_SORE
  MALAM
}

enum ConfirmedPatientStatus {
  TERKONFIRMASI
  SELESAI
  TIDAK_DATANG
  BATAL
}
